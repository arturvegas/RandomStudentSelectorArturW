<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RandomStudentSelectorArturW.Views.EditStudentsPage"
             Title="Edytuj Uczniow">
    <ContentPage.Resources>
        <StyleSheet Source="/Resources/Styles/AppStyles.css" />
    </ContentPage.Resources>

    <VerticalStackLayout Padding="15" Spacing="10">
        <Grid ColumnDefinitions="*,Auto" 
              Padding="10" 
              BackgroundColor="White">
            <Label x:Name="ClassNameLabel"
                   Text="Klasa: "
                   StyleClass="classNameLabel"
                   Grid.Column="0"
                   Padding="8"
                   FontSize="19"/>

            <Button Text="✏️"
                    Grid.Column="1"
                    StyleClass="editClassButton"
                    Clicked="OnEditClassNameClicked"
                    BackgroundColor="#2196F3"
                    Padding="8"
                    FontSize="16"/>
        </Grid>

        <Label Text="Dodaj ucznia:"
               StyleClass="sectionLabel"/>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Entry x:Name="StudentEntry"
                   Placeholder="Wpisz imię i nazwisko"
                   StyleClass="textEntry"
                   Grid.Column="0"/>

            <Button Text="+"
                    Clicked="OnAddStudentClicked"
                    StyleClass="addButton"
                    Grid.Column="1"/>
        </Grid>

        <Label Text="Lista uczniów:"
               StyleClass="sectionLabel"/>

        <ScrollView HeightRequest="400">
            <CollectionView x:Name="StudentsCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="15"
                              ColumnDefinitions="*,Auto,Auto"
                              BackgroundColor="#F5F5F5"
                              Margin="0,5">
                            <Label Text="{Binding .}"
                                   StyleClass="studentItemText"
                                   Grid.Column="0"
                                   Padding="8"
                                   FontSize="20"/>         

                            <Button Text="✏️"
                                    Grid.Column="1"
                                    Clicked="OnEditStudentClicked"
                                    BackgroundColor="#2196F3"
                                    TextColor="White"
                                    Padding="8"
                                    FontSize="16"
                                    CornerRadius="5"
                                    Margin="5,0"/>

                            <Button Text="🗑️"
                                    Grid.Column="2"
                                    Clicked="OnDeleteStudentClicked"
                                    BackgroundColor="#F44336"
                                    TextColor="White"
                                    Padding="8"
                                    FontSize="16"
                                    CornerRadius="5"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <Label x:Name="EmptyMessage"
               Text="Brak uczniów w tej klasie. Dodaj pierwszego ucznia używając pola powyżej!"
               StyleClass="emptyMessage"/>
    </VerticalStackLayout>
</ContentPage>
